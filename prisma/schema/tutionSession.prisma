model TuitionSession {
    id String @id @default(uuid())
    completed Boolean @default(false)
    time String 
    
    studentId String
    studentProfile StudentProfile @relation(fields: [studentId], references: [id])
    
    tutorId String
    tutorProfile TutorProfile @relation(fields: [tutorId], references: [id])

    @@unique([tutorId, time])
}