model TutorProfile {
    id String @id @default(uuid())
    ratingSum Int
    ratingCount Int 
    reviews Review[]
    availableTimes AvailableTime[]
    featured Boolean @default(false)
    subjects String[] @default([])
    category String @default("offline")
    price Int @default(5)

    user User @relation(fields: [userId], references: [id])
    userId String @unique

    tuitionSession TuitionSession[]

}

model Review {
    id String @id @default(uuid())
    content String 

    tutorProfile TutorProfile @relation(fields: [tutorProfileId], references: [id])
    tutorProfileId String 

    studentUserId String?
    studentId StudentProfile? @relation(fields: [studentUserId], references: [userId])
}


model AvailableTime {
    id String @id @default(uuid())
    day Days 
    startTime String
    endTime String 

    tutorProfile TutorProfile @relation(fields: [tutorProfileId], references: [id])
    tutorProfileId String 
}

enum Days {
    SUNDAY
    MONDAY
    TUESDAY 
    WEDNESDAY 
    THURSDAY 
    FRIDAY 
    SATURDAY 
}